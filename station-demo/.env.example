# Emergency Station Demo Environment Variables

# Main platform URL (deployed backend)
MAIN_PLATFORM_URL=https://disaster-resource-optimizer-ai-1.onrender.com

# Manager PIN for authenticating with main platform
MANAGER_PIN=0000

# MongoDB Atlas base URI (used by init-station-dbs.js)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/DisasterResponseDB?appName=Cluster0

# MongoDB Atlas URIs for each station type (each has its own database)
MONGO_URI_FIRE=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/emergency_station_fire?appName=Cluster0
MONGO_URI_HOSPITAL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/emergency_station_hospital?appName=Cluster0
MONGO_URI_POLICE=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/emergency_station_police?appName=Cluster0
MONGO_URI_RESCUE=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/emergency_station_rescue?appName=Cluster0

# Deployed station URLs on Render (set after deploying)
# Used by register-stations.js to tell the main backend where to send alerts
STATION_URL_FIRE=https://station-fire.onrender.com
STATION_URL_HOSPITAL=https://station-hospital.onrender.com
STATION_URL_POLICE=https://station-police.onrender.com
STATION_URL_RESCUE=https://station-rescue.onrender.com

# Station API Keys (should match what's registered on main platform)
STATION_API_KEY_FIRE=fire-station-demo-key-2024
STATION_API_KEY_HOSPITAL=hospital-demo-key-2024
STATION_API_KEY_POLICE=police-station-demo-key-2024
STATION_API_KEY_RESCUE=rescue-station-demo-key-2024
