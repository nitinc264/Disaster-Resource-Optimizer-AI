# =============================================================================
# Disaster Response Platform — Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# --- Core ---
NODE_ENV=development                       # development | production | test
PORT=3000

# --- Database (required) ---
MONGO_URI=mongodb://localhost:27017/DisasterResponseDB

# --- Session (required in production) ---
SESSION_SECRET=                            # openssl rand -hex 64

# --- CORS (required in production, comma-separated origins) ---
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Agent API Key (required in production) ---
AGENT_API_KEY=                             # openssl rand -hex 32

# --- AI / ML ---
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Twilio SMS ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# --- Cloudinary Image Uploads ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=disaster-response/reports/photos

# --- Geocoding ---
GEOCODE_DEFAULT_REGION=Pune, India

# --- Logging ---
LOG_LEVEL=debug                            # debug | info | warn | error
